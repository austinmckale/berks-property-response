# Environment variables — copy to .env.local

# Public site URL (used for canonical URLs, sitemap, schema)
NEXT_PUBLIC_SITE_URL=https://berkspropertyresponse.com

# Google Analytics 4 — optional until launch (see docs/seo-launch.md)
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Call/text tracking numbers — replace PLACEHOLDER before launch
# Set NEXT_PUBLIC_PHONE to your final CallRail, WhatConverts, or Google Voice tracking number.
# Call Now and Text Photos use the same number unless NEXT_PUBLIC_TEXT_NUMBER is set separately.
NEXT_PUBLIC_PHONE=(484) 525-0459
# NEXT_PUBLIC_TEXT_NUMBER=(484) 525-0459

# --- Lead notifications ---

# Discord: Server Settings → Integrations → Webhooks → New Webhook → copy URL
DISCORD_WEBHOOK_URL=

# Email via Resend (https://resend.com) — verify your sending domain first
RESEND_API_KEY=
# Must use a verified domain in Resend, e.g. Berks Property Response <leads@berkspropertyresponse.com>
LEAD_EMAIL_FROM=
# Where new-lead alerts are sent
LEAD_NOTIFICATION_EMAIL=

# Optional: webhook for Zapier, Make, Google Sheets, etc.
LEAD_WEBHOOK_URL=
