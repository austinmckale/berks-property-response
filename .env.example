# Environment variables — copy to .env.local

# --- Critical for production ---

# Public site URL (canonical URLs, sitemap, schema). Must be HTTPS custom domain in production.
# Do NOT use localhost or *.vercel.app as production canonical.
NEXT_PUBLIC_SITE_URL=https://berkspropertyresponse.com

# Confirmed BPR business number — REQUIRED in production (must be set explicitly in Vercel).
# Local/dev may omit this and fall back to (484) 509-0748 via DEFAULT_DEV_PHONE.
NEXT_PUBLIC_PHONE=(484) 509-0748
# SMS / text-photos number — set only when it differs from NEXT_PUBLIC_PHONE
# NEXT_PUBLIC_TEXT_NUMBER=

# At least ONE durable lead destination is required in production:
# Google Sheets Apps Script webhook (preferred ledger), OR
# complete Resend admin email (RESEND_API_KEY + LEAD_EMAIL_FROM + LEAD_NOTIFICATION_EMAIL).
# Discord alone is NOT sufficient — it is a secondary notification channel only.
LEAD_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=
RESEND_API_KEY=
LEAD_EMAIL_FROM=
LEAD_NOTIFICATION_EMAIL=

# --- Optional ---

# Public contact email shown on Contact / Privacy only when set
# NEXT_PUBLIC_CONTACT_EMAIL=hello@berkspropertyresponse.com

# Google Analytics 4 (optional until launch — see docs/seo-launch.md)
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Cloudflare Turnstile (optional). Form works without these.
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET_KEY=

# Upstash Redis REST — optional distributed rate limiting for /api/submit-lead
# Form still uses honeypot + timing checks when unset.
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
# LEAD_RATE_LIMIT_WINDOW_SEC=60
# LEAD_RATE_LIMIT_MAX=8

# Force production env validation to fail local builds (CI / pre-launch check)
# FORCE_PRODUCTION_ENV_CHECK=1
